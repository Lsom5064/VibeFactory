<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_app"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_top_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <ImageButton
                android:id="@+id/btnOpenDrawer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_surface_alt"
                android:contentDescription="@string/open_menu"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_sort_by_size" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textIsSelectable="true"
                    android:text="@string/app_title"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/inputModeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textIsSelectable="true"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_alt"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="8dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textIsSelectable="true"
                    android:text="@string/show_logs"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchShowLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:checked="false"
                    app:showText="false" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/chatCard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_surface_card">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMessages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp"
                android:paddingTop="16dp"
                android:paddingBottom="18dp" />

            <TextView
                android:id="@+id/emptyChatText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textIsSelectable="true"
                android:text="@string/empty_chat"
                android:textColor="@color/text_secondary" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/logPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_message_log"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/logPanelTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textIsSelectable="true"
                android:text="@string/message_title_log"
                android:textColor="@color/accent_primary_dark"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ScrollView
                android:id="@+id/logPanelScroll"
                android:layout_width="match_parent"
                android:layout_marginTop="6dp"
                android:layout_height="160dp"
                android:fillViewport="true"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/logPanelBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textIsSelectable="true"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />
            </ScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/downloadArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_surface_alt"
            android:orientation="horizontal"
            android:padding="10dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnDownloadManual"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:textColor="@color/text_primary"
                android:text="@string/download_apk" />

            <Button
                android:id="@+id/btnInstallLatest"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_primary"
                android:textColor="@color/text_inverse"
                android:text="@string/install_apk"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/composerBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_composer"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/inputPrompt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="@string/prompt_hint_new"
                    android:minHeight="48dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:padding="12dp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnAttachReferenceImage"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/attach_reference_image"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:tint="@color/text_secondary" />

            <ImageView
                android:id="@+id/selectedReferenceImagePreview"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_surface_alt"
                android:clipToOutline="true"
                android:contentDescription="@string/reference_image_preview_content_description"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_primary"
                android:minWidth="72dp"
                android:text="@string/send"
                android:textColor="@color/text_inverse" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/drawerContent"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/bg_panel"
        android:elevation="16dp"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textIsSelectable="true"
            android:text="@string/history_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textIsSelectable="true"
            android:text="@string/drawer_subtitle"
            android:textColor="@color/text_secondary" />

        <Button
            android:id="@+id/btnNewChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_primary"
            android:text="@string/new_chat"
            android:textColor="@color/text_inverse" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTasks"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/phoneGateOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_app"
        android:clickable="true"
        android:elevation="24dp"
        android:focusable="true"
        android:visibility="gone">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/phoneGateContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|center_horizontal"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textIsSelectable="true"
                        android:text="@string/phone_gate_title"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textIsSelectable="true"
                        android:text="@string/phone_gate_subtitle"
                        android:textColor="@color/text_secondary" />

                    <EditText
                        android:id="@+id/inputPhoneGate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@android:color/transparent"
                        android:hint="@string/phone_gate_hint"
                        android:inputType="phone"
                        android:minHeight="52dp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <Button
                        android:id="@+id/btnSavePhoneGate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_button_primary"
                        android:text="@string/phone_gate_continue"
                        android:textColor="@color/text_inverse" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>
</androidx.drawerlayout.widget.DrawerLayout>

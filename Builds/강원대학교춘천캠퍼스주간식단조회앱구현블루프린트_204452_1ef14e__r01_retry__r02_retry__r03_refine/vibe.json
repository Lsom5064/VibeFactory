{"task_id": "204452_1ef14e", "package_name": "kr.ac.kangwon.hai.knumeal.t204452_1ef14e", "app_name": "\uac15\uc6d0\ub300\ud559\uad50 \ucd98\ucc9c\ucea0\ud37c\uc2a4 \uc8fc\uac04 \uc2dd\ub2e8 \uc870\ud68c \uc571 \uad6c\ud604 \ube14\ub8e8\ud504\ub9b0\ud2b8", "build_spec": {"app_goal": "\uac15\uc6d0\ub300\ud559\uad50 \ucd98\ucc9c\ucea0\ud37c\uc2a4 \ud559\uc2dd\ub2f9\uc758 \uc8fc\uac04 \uc2dd\ub2e8\ud45c\ub97c \uacf5\uc2dd \uc6f9\ud398\uc774\uc9c0 \uae30\uc900\uc73c\ub85c \uc870\ud68c\ud558\ub294 \uc548\ub4dc\ub85c\uc774\ub4dc \uc571 \uc81c\uc791", "target_users": "\uac15\uc6d0\ub300\ud559\uad50 \ucd98\ucc9c\ucea0\ud37c\uc2a4 \ud559\uc0dd, \uad50\uc9c1\uc6d0, \ubc29\ubb38\uc790", "core_features": ["\uacf5\uc2dd \uae08\uc8fc\uc758 \uc2dd\ub2e8 \ud398\uc774\uc9c0\uc5d0\uc11c \uc8fc\uac04 \uba54\ub274 \uc2e4\uc2dc\uac04 \uc870\ud68c", "\uc2dd\ub2f9 \ub610\ub294 \ucf54\ub108\ubcc4 \uba54\ub274 \uad6c\ubd84 \ud45c\uc2dc", "\uc8fc\uac04 \ubc94\uc704 \ud45c\uc2dc \ubc0f \uc774\uc804\u00b7\ub2e4\uc74c \uc8fc \ud0d0\uc0c9 UI", "\uc810\uc2ec\u00b7\uc800\ub141 \ub4f1 \uc2dd\uc0ac \uad6c\ubd84 \ud45c\uc2dc", "\ucd5c\uadfc \uc870\ud68c \uacb0\uacfc \ub85c\uceec \uce90\uc2dc\ub85c \uc7ac\ud45c\uc2dc"], "screens": ["\ud648 \ud654\uba74", "\uc8fc\uac04 \uc2dd\ub2e8\ud45c \ud654\uba74", "\uc2dd\ub2f9/\ucf54\ub108 \uc120\ud0dd \ud654\uba74", "\uc624\ud504\ub77c\uc778 \uce90\uc2dc \ubcf4\uae30 \ud654\uba74", "\uc571 \uc815\ubcf4 \ubc0f \ucd9c\ucc98 \ud654\uba74"], "data_model": "mixed", "auth": "not_required", "online_mode": "hybrid", "constraints": ["\uacf5\uc2dd \ucd9c\ucc98\ub294 \uc6f9\ud398\uc774\uc9c0\uc774\uba70 \uacf5\uac1c API \uba85\uc138\ub294 \uc81c\uacf5\ub418\uc9c0 \uc54a\uc558\uc2b5\ub2c8\ub2e4.", "\uba54\ub274 \ub370\uc774\ud130\ub294 \uc6f9\ud398\uc774\uc9c0 \uad6c\uc870\uc5d0 \uc758\uc874\ud558\ubbc0\ub85c \ud30c\uc11c\uac00 \ud398\uc774\uc9c0 \ubcc0\uacbd\uc5d0 \ubbfc\uac10\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "\uc5f0\uad6c \uacb0\uacfc\uc5d0\uc11c \ucd98\ucc9c\ucea0\ud37c\uc2a4 \uae08\uc8fc\uc758 \uc2dd\ub2e8 \ud398\uc774\uc9c0\uc758 \uc2e4\uc81c \ud14d\uc2a4\ud2b8\uac00 \ud655\uc778\ub418\uc5c8\uc73c\ubbc0\ub85c \uc774\ub97c 1\ucc28 \ucd9c\ucc98\ub85c \uc0ac\uc6a9\ud569\ub2c8\ub2e4.", "\uc8fc\uac04 \uc774\ub3d9 \ubc84\ud2bc\uc774 \ud398\uc774\uc9c0\uc5d0 \uc874\uc7ac\ud558\ub294 \uac83\uc73c\ub85c \ubcf4\uc774\uc9c0\ub9cc \uc2e4\uc81c \uc694\uccad \ubc29\uc2dd\uc740 \ud655\uc778\ub418\uc9c0 \uc54a\uc558\uc73c\ubbc0\ub85c \ucd08\uae30 \ubc84\uc804\uc740 \ud604\uc7ac \uc8fc \uc911\uc2ec \uc870\ud68c\ub97c \uc6b0\uc120 \uad6c\ud604\ud558\ub294 \uac83\uc774 \uc548\uc804\ud569\ub2c8\ub2e4.", "\uc2dd\ub2f9\uba85\uacfc \ucf54\ub108\uba85 \ud14d\uc2a4\ud2b8\uac00 \ud63c\uc7ac\ub418\uc5b4 \uc788\uc5b4 \ud654\uba74\uc5d0\uc11c\ub294 \uc2dd\ub2f9 \ud0ed\uacfc \ucf54\ub108 \uc139\uc158\uc744 \ubd84\ub9ac\ud574 \ud45c\uc2dc\ud574\uc57c \ud569\ub2c8\ub2e4."], "data_strategy": "runtime_web_fetch", "external_sources": [{"title": "\uac15\uc6d0\ub300\ud559\uad50 \ucd98\ucc9c\ucea0\ud37c\uc2a4 \uae08\uc8fc\uc758 \uc2dd\ub2e8", "url": "https://kangwon.ac.kr/ko/extn/37/wkmenu-mngr/list.do?campusCd=1", "source_type": "official_page"}, {"title": "\uac15\uc6d0\ub300\ud559\uad50 \ud6c4\uc0dd\ubcf5\uc9c0 \ucd98\ucc9c\ucea0\ud37c\uc2a4 \uc548\ub0b4", "url": "https://kangwon.ac.kr/ko/conts/36/directory.do", "source_type": "official_page"}], "data_source_type": "web_scrape", "source_access_mode": "scraping", "source_url_candidates": ["https://kangwon.ac.kr/ko/extn/37/wkmenu-mngr/list.do?campusCd=1", "https://kangwon.ac.kr/ko/conts/36/directory.do"], "required_permissions": [{"name": "android.permission.INTERNET", "usage_reason": "\uacf5\uc2dd \uc6f9\ud398\uc774\uc9c0\uc5d0\uc11c \ucd5c\uc2e0 \uc8fc\uac04 \uc2dd\ub2e8 \uc815\ubcf4\ub97c \ubd88\ub7ec\uc624\ub294 \ub370 \ud544\uc694", "runtime_request_required": false}], "permission_requirements": {"runtime_prompt_required": false, "denial_fallback_required": true}, "verification_requirements": {"requires_external_data_verification": true, "source_probe_required": true, "migration_notice_check": true, "parser_smoke_test_required": true, "minimum_sample_days": 1, "cache_persistence_required": true}}, "verification_summary": "\uacf5\uc2dd \uc2dd\ub2e8 \ud398\uc774\uc9c0 \uc751\ub2f5\uacfc \uc0d8\ud50c \uba54\ub274 \ub370\uc774\ud130\ub294 \ud655\uc778\ub418\uc5c8\uace0 \ub85c\uceec \uce90\uc2dc \uc800\uc7a5\ub3c4 \uad6c\ud604\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub7ec\ub098 \ucf54\ub4dc\uc758 DOM \ud30c\uc11c\ub294 \uc2e4\uc81c \ud398\uc774\uc9c0 \uad6c\uc870\uc640 \ub9de\uc9c0 \uc54a\uc544 \uc2dd\ub2f9 \ud0ed\uacfc \uc2dd\ub2e8 \ud45c\ub97c \uc548\uc815\uc801\uc73c\ub85c \uc77d\uc744 \uadfc\uac70\uac00 \ubd80\uc871\ud558\uba70, \ubcf4\uc870 \ucd9c\ucc98 \ud6c4\ubcf4\ub3c4 \uc2e4\uc81c\ub85c\ub294 \uac19\uc740 \uc2dd\ub2e8 \ud398\uc774\uc9c0\ub85c \uc774\ub3d9\ud569\ub2c8\ub2e4. \ub610\ud55c fetched source\uc5d0 \uc774\uc804 \uc548\ub0b4\ub85c \ud574\uc11d\ub420 \uc218 \uc788\ub294 \uc2e0\ud638\uac00 \uc788\uc5b4 \ube4c\ub4dc \uc131\uacf5\ub9cc\uc73c\ub85c \uc2e4\uc81c \uc2dd\ub2e8 \uc870\ud68c \uae30\ub2a5 \ub3d9\uc791\uc744 \ubcf4\uc7a5\ud558\uae30 \uc5b4\ub835\uc2b5\ub2c8\ub2e4.", "verification_status": "fail"}
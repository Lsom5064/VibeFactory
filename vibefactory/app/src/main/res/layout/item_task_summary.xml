<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="#EEF3F8"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/taskRuntimeBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#FFE2E2"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="@string/runtime_badge"
        android:textColor="#C62828"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/taskTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="2"
            android:textColor="#1C1E21"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnHideTask"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/task_hide_from_chat_list"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="@color/text_secondary" />
    </LinearLayout>

    <TextView
        android:id="@+id/taskSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#666666"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/taskStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#007AFF"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>

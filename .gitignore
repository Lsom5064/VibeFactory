# macOS / editor noise
.DS_Store
**/.DS_Store
*.swp
*.swo
.idea/
**/.idea/
.vscode/

# Local secrets and machine-specific config
.env
.env.*
!.env.example
*.pem
*.key
*.keystore
*.jks
key.properties
**/local.properties

# AWS deployment: keep scripts/templates, ignore private downloads and keys
aws/*.pem
aws/*.key
aws/*.env
!aws/*.env.example
aws/downloads/

# Server runtime data. Keep these on the server/data volume, not in Git.
flutter_apk_server/tasks.db*
flutter_apk_server/*.sqlite*
flutter_apk_server/workspaces/
flutter_apk_server/profiles/
flutter_apk_server/logs/
flutter_apk_server/uploads/
flutter_apk_server/.venv/
flutter_apk_server/venv/

# Generated task workspaces/results
**/workspaces/
**/.codex_result/
**/.작업 엔진_result/
**/.tmp_codex_home/

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/

# Node / frontend tooling
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Flutter / Dart
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/coverage/
**/build/

# Android / Gradle build outputs
**/.gradle/
**/.cxx/
**/.externalNativeBuild/
**/captures/
**/app/debug/
**/app/profile/
**/app/release/
*.apk
*.aab
*.apks

# Logs and temporary files
*.log
*.tmp
*.temp

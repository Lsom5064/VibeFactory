BASE_PROJECT_PATH=/opt/vibefactory/BaseProject
WORKSPACES_ROOT=/srv/vibefactory/workspaces
DB_PATH=/srv/vibefactory/tasks.db
SERVER_BASE_URL=http://15.165.191.202

FLUTTER_COMMAND=/opt/flutter/bin/flutter
CODEX_TIMEOUT_SECONDS=1800
MAX_CONCURRENT_CODEX_RUNS=1
CODEX_DANGEROUS_BYPASS=1

# First boot should stay in mock mode until HTTP routing is verified.
MOCK_CODEX=1
INTENT_AGENT_ENABLED=0
INTENT_AGENT_MODEL=gpt-5.4
INTENT_AGENT_TIMEOUT_SECONDS=20
CODEX_EXISTING_TASK_FOLLOWUP_ENABLED=1
CODEX_FOLLOWUP_DECISION_TIMEOUT_SECONDS=90

# Required for real intent/spec clarification.
OPENAI_API_KEY=

# Optional runtime LLM endpoint for generated apps.
APP_RUNTIME_OPENAI_API_KEY=
APP_RUNTIME_MODEL=gpt-5.4-mini
APP_RUNTIME_DAILY_REQUEST_LIMIT=100
APP_RUNTIME_DAILY_TOKEN_LIMIT=50000

# Set this before exposing /admin/*.
ADMIN_API_TOKEN=
